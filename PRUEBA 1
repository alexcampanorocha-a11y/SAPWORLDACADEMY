          SAP World Academy Oficial
        </p>
        <h2 className="text-3xl font-extrabold text-slate-900">{data.curso}</h2>
      </div>

      <div className="p-8 grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
        {/* Detalles del estudiante */}
