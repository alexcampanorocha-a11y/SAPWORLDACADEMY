// COMPONENTE: Sección de Administración (Crear)
function SeccionAdministracion({ mockDB, setMockDB }) {
  const [formData, setFormData] = useState({
    codigo: '', nombre: '', curso: '', horas: '', nota: '', fecha: new Date().toISOString().split('T')[0]
  });
  const [estado, setEstado] = useState({ tipo: '', msj: '' });

  const generarCodigo = () => {
    const randomNum = Math.floor(1000 + Math.random() * 9000);
    setFormData({ ...formData, codigo: `CERT-${new Date().getFullYear()}-${randomNum}` });
  };

  const manejarEnvio = async (e) => {
    e.preventDefault();
    setEstado({ tipo: 'loading', msj: 'Procesando...' });

    try {
      // Simular guardado
      setTimeout(() => {
        const existe = mockDB.some(c => c.codigo === formData.codigo);
        if (existe) {
          setEstado({ tipo: 'error', msj: 'El código de certificado ya existe.' });
        } else {
          setMockDB([{ ...formData, estado: 'Válido' }, ...mockDB]);
          setEstado({ tipo: 'success', msj: '¡Certificado emitido y guardado exitosamente!' });
          setFormData({ codigo: '', nombre: '', curso: '', horas: '', nota: '', fecha: new Date().toISOString().split('T')[0] });
        }
      }, 600);
    } catch (err) {
      setEstado({ tipo: 'error', msj: 'Error al crear el certificado.' });
    }
  };

  return (
    <div className="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
      <div className="flex items-center gap-4 mb-8 pb-6 border-b border-slate-100">
        <div className="bg-blue-50 p-3 rounded-xl border border-blue-100">
          <Award className="h-7 w-7 text-blue-600" />
        </div>
        <div>
          <h2 className="text-2xl font-extrabold text-slate-900">Emisión de Certificados</h2>
          <p className="text-slate-500 text-sm mt-1">Plataforma administrativa SAP World Academy</p>
        </div>
      </div>

      {estado.msj && (
        <div className={`p-4 rounded-xl mb-6 flex items-start gap-3 ${
          estado.tipo === 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 
          estado.tipo === 'error' ? 'bg-red-50 text-red-800 border border-red-200' : 
          'bg-blue-50 text-blue-800 border border-blue-200'
        }`}>
          {estado.tipo === 'success' && <CheckCircle2 className="h-5 w-5 mt-0.5 shrink-0" />}
          {estado.tipo === 'error' && <AlertCircle className="h-5 w-5 mt-0.5 shrink-0" />}
          <p className="font-medium">{estado.msj}</p>
        </div>
      )}

      <form onSubmit={manejarEnvio} className="space-y-6">
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div className="col-span-1 md:col-span-2">
            <label className="block text-sm font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Nombre Completo del Alumno</label>
            <input
              type="text" required
              value={formData.nombre}
              onChange={e => setFormData({...formData, nombre: e.target.value})}
              className="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none transition-all bg-slate-50 focus:bg-white"
              placeholder="Ej. María Elena Salinas"
            />
          </div>

          <div className="col-span-1 md:col-span-2">
            <label className="block text-sm font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Programa / Curso SAP</label>
            <input
              type="text" required
              value={formData.curso}
              onChange={e => setFormData({...formData, curso: e.target.value})}
              className="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none transition-all bg-slate-50 focus:bg-white"
              placeholder="Ej. SAP S/4HANA Finance Master"
            />
          </div>

          <div>
            <label className="block text-sm font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Horas Lectivas</label>
            <input
              type="number" required min="1"
              value={formData.horas}
              onChange={e => setFormData({...formData, horas: e.target.value})}
              className="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none transition-all bg-slate-50 focus:bg-white"
              placeholder="Ej. 120"
            />
          </div>

          <div>
            <label className="block text-sm font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Nota Final</label>
            <input
              type="text" 
              value={formData.nota}
              onChange={e => setFormData({...formData, nota: e.target.value})}
              className="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none transition-all bg-slate-50 focus:bg-white"
              placeholder="Ej. 19"
            />
          </div>

          <div>
            <label className="block text-sm font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Fecha de Emisión</label>
            <input
              type="date" required
              value={formData.fecha}
              onChange={e => setFormData({...formData, fecha: e.target.value})}
              className="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none transition-all bg-slate-50 focus:bg-white"
            />
          </div>

          <div>
            <label className="block text-sm font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Código Único (ID)</label>
            <div className="flex gap-2">
              <input
                type="text" required
                value={formData.codigo}
                onChange={e => setFormData({...formData, codigo: e.target.value})}
                className="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none transition-all font-mono text-sm bg-slate-50 focus:bg-white"
                placeholder="CERT-..."
              />
              <button
                type="button" 
                onClick={generarCodigo}
                className="px-4 bg-slate-800 hover:bg-slate-900 text-white rounded-xl text-sm font-bold transition-colors shadow-sm"
                title="Generar código automático"
              >
                Auto
              </button>
            </div>
          </div>
        </div>

        <div className="pt-6 mt-8 border-t border-slate-100 flex justify-end">
          <button
            type="submit" 
            disabled={estado.tipo === 'loading'}
            className="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3.5 rounded-xl font-bold transition-all shadow-md disabled:opacity-70 w-full sm:w-auto text-lg"
          >
            {estado.tipo === 'loading' ? 'Emitiendo...' : 'Emitir Certificado Oficial'}
          </button>
        </div>
      </form>
    </div>
  );
}

